# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, NEVER expose to client

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000          # used to build QR verification URLs

# Storage bucket name for uploaded PDF templates & generated certificates
SUPABASE_TEMPLATE_BUCKET=templates
SUPABASE_CERTIFICATE_BUCKET=certificates
