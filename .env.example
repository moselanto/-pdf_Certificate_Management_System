# CertForge — environment variables
# Copy this file to `.env.local` for local dev, OR paste these keys into your
# host's Environment Variables panel (Vercel: Project Settings > Environment
# Variables; cPanel: Setup Node.js App > environment variables).
#
# NEVER commit real values. This file lists names + example shapes only.

# --- Supabase (backend: Postgres + Auth + Storage) ---------------------------
# From your Supabase project: Settings > API.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key (safe to expose to the browser; RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Service role key — SERVER ONLY. Full DB access, bypasses RLS.
# Never prefix this with NEXT_PUBLIC_ and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# --- App URL -----------------------------------------------------------------
# The public base URL of the deployed app. CRITICAL: the certificate QR codes
# and the /verify links are built from this. It MUST be your real production
# domain in production, or scanned certificates will not verify.
#
#   Local dev:   http://localhost:3000
#   Production:  https://certforge.yourdomain.com   (use your actual domain)
NEXT_PUBLIC_APP_URL=https://certforge.yourdomain.com
